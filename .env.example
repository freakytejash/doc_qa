# LLM Configuration
LLM_PROVIDER=openai                              # Routes to Groq API
OPENAI_API_KEY=gsk_YOUR_GROQ_API_KEY           # Groq API key from https://console.groq.com
LLM_MODEL=llama-3.1-8b-instant                 # Chat model (Groq hosted)

# Embeddings Configuration
EMBEDDING_PROVIDER=huggingface                  # Local embeddings
HF_EMBEDDING_MODEL=all-MiniLM-L6-v2            # Fast, 384-dim embeddings

# Vector Database
CHROMA_PERSIST_DIR=./chroma_db                 # Where to store embeddings
CHROMA_COLLECTION_NAME=documents               # Collection name

# Chunking Strategy
CHUNK_SIZE=500                                 # Max characters per chunk
CHUNK_OVERLAP=50                               # Overlap between chunks
TOP_K=5                                        # Results per query

# Vision Model (Optional - for diagram descriptions)
VISION_ENABLED=true                            # Enable vision descriptions
VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct  # Vision model (Groq)
